OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Mock calendar (default true). Set to false to use Google after OAuth.
MOCK_CALENDAR_DEFAULT=true

# Google OAuth — create OAuth Client (Web) in Google Cloud Console; add redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated; must match Google Cloud Authorized redirect URIs exactly.
# Required for the default flow (single URI — no Vite port):
# http://localhost:8000/api/auth/google/callback
# Optional legacy SPA callback URIs are listed in app/config.py defaults.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback,http://localhost:5173/oauth/callback,http://127.0.0.1:5173/oauth/callback,http://localhost:5173/,http://127.0.0.1:5173/

PUBLIC_BACKEND_URL=http://localhost:8000
# Optional: force the exact redirect_uri sent to Google (must match Console). Default: {PUBLIC_BACKEND_URL}/api/auth/google/callback
# GOOGLE_OAUTH_CALLBACK_URI=
DATA_DIR=.data
IDLE_CONSOLIDATION_SECONDS=60
